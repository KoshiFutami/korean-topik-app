            "body": {
              "mode": "raw",
              "raw": "{\n  \"term\": \"손을 씻다\",\n  \"meaning_ja\": \"手を洗う\",\n  \"pos\": \"verb\",\n  \"level\": 1,\n  \"entry_type\": \"phrase\",\n  \"example_sentence\": \"밥 먹기 전에 손을 씻어요.\",\n  \"example_translation_ja\": \"ご飯を食べる前に手を洗います。\",\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/vocabularies",
