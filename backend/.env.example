APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# 語彙音声など public ディスクの URL に使われる。Docker 例は :8000（フロントの NEXT_PUBLIC_API_URL と揃える）
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# 語彙音声の保存ディスク: ローカルは 'public'（デフォルト）、本番は 'audio_gcs'（GCS）または 'audio_s3'（S3）
# AUDIO_STORAGE_DISK=audio_gcs

# GCS 音声バケット（AUDIO_STORAGE_DISK=audio_gcs のときに使用）
# GCS_AUDIO_BUCKET=korean-topik-audio
# GCS_AUDIO_PATH_PREFIX=

# プロフィール画像の保存ディスク: ローカルは 'public'（デフォルト）、本番は 'profile_image_gcs'（GCS）
# PROFILE_IMAGE_STORAGE_DISK=profile_image_gcs

# GCS プロフィール画像バケット（PROFILE_IMAGE_STORAGE_DISK=profile_image_gcs のときに使用）
# GCS_PROFILE_IMAGE_BUCKET=korean-topik-app-prod-profile-image
# GCS_PROFILE_IMAGE_PATH_PREFIX=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ブラウザから API を叩くフロント（Vercel 等）のオリジン。カンマ区切りで複数指定可。
# 例: https://korean-topik-app.vercel.app,https://korean-topik-app-xxx.vercel.app
# CORS_ALLOWED_ORIGINS=

# Google Cloud 認証（TTS・GCS 共通）
# 認証方法（どちらか一方を設定する）:
# - GOOGLE_CREDENTIALS_B64: base64 エンコードした JSON（Railway 等エフェメラル環境向け。TTS と GCS で共用）
#     生成方法: base64 -i tts-credentials.json | tr -d '\n'
# - GOOGLE_APPLICATION_CREDENTIALS: サービスアカウント JSON ファイルのパス（Docker 等の永続ファイルシステム向け）
#     相対パスは backend/ 基準。Docker ではコンテナ内の絶対パスを推奨。
#     例: GOOGLE_APPLICATION_CREDENTIALS=/var/www/html/storage/credentials/tts-credentials.json
# GOOGLE_CREDENTIALS_B64=
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_TTS_LANGUAGE_CODE=ko-KR
# GOOGLE_TTS_VOICE=ko-KR-Neural2-A
